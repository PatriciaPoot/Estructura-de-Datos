import tkinter as tk
from tkinter import ttk, scrolledtext, filedialog, messagebox
import matplotlib.pyplot as plt
from matplotlib.backends.backend_tkagg import FigureCanvasTkAgg
import time
import threading
import os
import re # Librería para limpieza avanzada de texto
from datetime import datetime

try:
    import openpyxl
    EXCEL_SUPPORT = True
except ImportError:
    EXCEL_SUPPORT = False

class VentanaSelectorHojas(tk.Toplevel):
    def __init__(self, parent, nombre_archivo, lista_hojas):
        super().__init__(parent)
        self.title(f"Hojas de: {nombre_archivo}")
        self.geometry("400x500")
        self.configure(bg="#2d2d2d")
        self.resizable(False, False)
        
        self.resultado = []
        self.vars = []

        tk.Label(self, text="ARCHIVO EXCEL DETECTADO:", bg="#2d2d2d", fg="#ffb3ba", font=("Arial", 10, "bold")).pack(pady=10)
        tk.Label(self, text=nombre_archivo, bg="#2d2d2d", fg="white", wraplength=350).pack()

        # Contenedor con Scroll
        container = tk.Frame(self, bg="#1e1e1e")
        container.pack(fill="both", expand=True, padx=20, pady=20)
        
        canvas = tk.Canvas(container, bg="#1e1e1e", highlightthickness=0)
        scrollbar = tk.Scrollbar(container, orient="vertical", command=canvas.yview)
        scroll_frame = tk.Frame(canvas, bg="#1e1e1e")

        scroll_frame.bind("<Configure>", lambda e: canvas.configure(scrollregion=canvas.bbox("all")))
        canvas.create_window((0, 0), window=scroll_frame, anchor="nw")
        canvas.configure(yscrollcommand=scrollbar.set)

        # Si no hay hojas, avisar
        if not lista_hojas:
            tk.Label(scroll_frame, text="No se encontraron hojas.", bg="#1e1e1e", fg="red").pack()

        for hoja in lista_hojas:
            var = tk.BooleanVar(value=True)
            chk = tk.Checkbutton(scroll_frame, text=hoja, variable=var, bg="#1e1e1e", fg="white", 
                                 selectcolor="#2d2d2d", activebackground="#333", font=("Arial", 10))
            chk.pack(anchor="w", padx=10, pady=5)
            self.vars.append((hoja, var))

        canvas.pack(side="left", fill="both", expand=True)
        scrollbar.pack(side="right", fill="y")

        tk.Button(self, text="ACEPTAR Y PROCESAR", command=self.confirmar, 
                  bg="#baffc9", fg="black", font=("Arial", 10, "bold"), pady=10).pack(fill="x", padx=20, pady=10)
        
        self.transient(parent)
        self.grab_set() 
        self.wait_window()

    def confirmar(self):
        self.resultado = [hoja for hoja, var in self.vars if var.get()]
        self.destroy()

class AppFinal:
    def __init__(self, root):
        self.root = root
        self.root.title("Sistema de Ordenamiento Multi-Formato")
        self.root.geometry("1100x800")
        self.root.configure(bg="#1e1e1e")
        self.archivos = []
        self.metodo = tk.IntVar(value=1)
        self.setup_ui()

    def setup_ui(self):
        header = tk.Frame(self.root, bg="#2d2d2d", pady=20)
        header.pack(fill="x")
        tk.Label(header, text="ORDENADOR UNIVERSAL PRO", bg="#2d2d2d", fg="#ffb3ba", font=("Arial", 18, "bold")).pack()

        m_frame = tk.LabelFrame(header, text=" Método de Ordenamiento ", bg="#2d2d2d", fg="white", pady=5)
        m_frame.pack(pady=10)
        for t, v in [("Intercalación", 1), ("Mezcla Directa", 2), ("Mezcla Equilibrada", 3)]:
            tk.Radiobutton(m_frame, text=t, variable=self.metodo, value=v, bg="#2d2d2d", fg="#bae1ff", selectcolor="#1e1e1e").pack(side=tk.LEFT, padx=15)

        b_frame = tk.Frame(header, bg="#2d2d2d")
        b_frame.pack(pady=10)
        tk.Button(b_frame, text="📂 Cargar Archivos", bg="#ffffba", command=self.seleccionar, width=25, font=("Arial", 10, "bold")).pack(side=tk.LEFT, padx=10)
        tk.Button(b_frame, text="🚀 Ejecutar Fusión", bg="#baffc9", command=self.ejecutar, width=25, font=("Arial", 10, "bold")).pack(side=tk.LEFT, padx=10)

        body = tk.Frame(self.root, bg="#1e1e1e")
        body.pack(fill="both", expand=True, padx=15, pady=15)
        
        self.log_widget = scrolledtext.ScrolledText(body, bg="#252526", fg="#d4d4d4", font=("Consolas", 10))
        self.log_widget.pack(fill="both", expand=True)

    def log(self, txt):
        self.log_widget.insert(tk.END, f"[{time.strftime('%H:%M:%S')}] • {txt}\n")
        self.log_widget.see(tk.END)

    def seleccionar(self):
        f = filedialog.askopenfilenames(title="Selecciona archivos")
        if f:
            self.archivos = list(f)
            self.log_widget.delete('1.0', tk.END)
            self.log(f"Cargados {len(f)} archivos.")

    def ejecutar(self):
        if not self.archivos:
            messagebox.showwarning("Atención", "Selecciona archivos primero.")
            return
        threading.Thread(target=self.proceso, daemon=True).start()

    def proceso(self):
        try:
            datos_totales = []
            for path in self.archivos:
                nombre = os.path.basename(path)
                ext = os.path.splitext(path)[1].lower()

                if ext == ".xlsx" and EXCEL_SUPPORT:
                    self.log(f"Analizando Excel: {nombre}")
                    wb = openpyxl.load_workbook(path, data_only=True)
                    # El selector se abre en el hilo principal para evitar que la lista salga vacía
                    hojas = self.root.after(0, lambda: VentanaSelectorHojas(self.root, nombre, wb.sheetnames))
                    
                    # Pequeña pausa para que el usuario elija
                    v = VentanaSelectorHojas(self.root, nombre, wb.sheetnames)
                    eleccion = v.resultado

                    for h in eleccion:
                        self.log(f"  Leyendo hoja: {h}")
                        ws = wb[h]
                        for fila in ws.iter_rows(values_only=True):
                            for c in fila:
                                if c is not None:
                                    try: datos_totales.append(int(float(str(c))))
                                    except: continue
                else:
                    self.log(f"Leyendo texto: {nombre}")
                    with open(path, 'r', errors='ignore') as f:
                        contenido = f.read()
                        # LIMPIEZA AVANZADA: Extraer todos los números ignorando comas, puntos y texto
                        numeros_encontrados = re.findall(r'-?\d+', contenido)
                        for n in numeros_encontrados:
                            datos_totales.append(int(n))

            if not datos_totales:
                self.log("ERROR: No se encontraron datos numéricos.")
                return

            self.log(f"Fusionados {len(datos_totales)} números. Ordenando...")
            datos_totales.sort()
            
            ts = datetime.now().strftime("%H%M%S")
            salida = f"FUSION_RESULTADO_{ts}.txt"
            with open(salida, "w") as f_out:
                for n in datos_totales: f_out.write(f"{n}\n")
            
            self.log(f"EXITO: Creado {salida}")
            messagebox.showinfo("Completado", f"Archivo generado:\n{salida}")

        except Exception as e:
            self.log(f"ERROR: {str(e)}")

if __name__ == "__main__":
    root = tk.Tk()
    app = AppFinal(root)
    root.mainloop()
